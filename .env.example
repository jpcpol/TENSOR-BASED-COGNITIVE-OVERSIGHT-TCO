# Copy to .env and fill in real values — never commit .env to git

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Database
POSTGRES_DB=tco_experiment
POSTGRES_USER=tco
POSTGRES_PASSWORD=tco
DATABASE_URL=postgresql://tco:tco@localhost:5432/tco_experiment

# Redis
REDIS_URL=redis://localhost:6379/0

# Services
TCO_ENGINE_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Experiment
EXPERIMENT_MODE=development   # development | pilot | full
TENSOR_CACHE_TTL=30           # seconds
POLICY_WINDOW_CYCLES=3        # Δ_post measurement window (H5)
